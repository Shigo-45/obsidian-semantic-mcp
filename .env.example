GEMINI_API_KEY=your-google-ai-studio-key-here
VAULT_PATH=/path/to/your/obsidian/vault
CHROMA_PERSIST_DIR=~/.obsidian-mcp/chroma
WATCH_VAULT=true

# Rate limiting — EMBED_RPM means "embeddings per minute" (NOT API calls)
# The API call interval is: 60 / (EMBED_RPM / EMBED_BATCH_SIZE)
#
# Paid tier 1 (3K embeddings/min, recommended):
EMBED_RPM=3000
#
# Free tier (~100-150 embeddings/min):
#   EMBED_RPM=100
#   EMBED_BATCH_SIZE=50
#
# For backwards compatibility, EMBED_RPS is read if EMBED_RPM is unset:
#   EMBED_RPS=2.0 → EMBED_RPM=120

# Batch size for text embedding API calls (Gemini limit: 100)
EMBED_BATCH_SIZE=100

# Minimum batch size when adaptive backoff reduces it (floor)
# EMBED_MIN_BATCH_SIZE=10

# Batch size reduction factor on consecutive 429s (0.5 = halve each time)
# EMBED_BACKOFF_BATCH_FACTOR=0.5

# Successful batches before restoring full batch size (0 = disabled)
# EMBED_BACKOFF_RECOVERY_STEPS=5

# Retry configuration — exponential backoff with jitter
# EMBED_MAX_RETRIES=3
# EMBED_RETRY_BASE_DELAY=5
# EMBED_RETRY_MAX_DELAY=120

# Ingestion parallelism — keep low for free tier (1), raise for paid tier
# INGEST_WORKERS=2

# Diagnostic logging for rate-limit analysis (429 debugging)
# Enable with: EMBED_DIAG_LOG=true
# EMBED_DIAG_LOG_FILE=/path/to/diag.log
